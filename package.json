{
	"name": "@repobuddy/storybook-monorepo",
	"version": "0.0.0",
	"private": true,
	"keywords": [],
	"license": "MIT",
	"author": {
		"name": "Homa Wong",
		"email": "homawong@gmail.com",
		"url": "https://github.com/unional"
	},
	"scripts": {
		"app": "pnpm --filter ./apps/app",
		"build": "turbo run build",
		"build:doc": "turbo run sb:build",
		"biome:check": "biome check",
		"biome:check:fix": "biome check --fix",
		"check": "run-p biome:check knip",
		"check:fix": "run-p biome:check:fix knip:fix",
		"clean": "turbo clean",
		"cov": "turbo cov",
		"cs": "changeset",
		"knip": "knip",
		"knip:fix": "knip --fix",
		"nuke": "turbo nuke && rimraf node_modules",
		"playwright:i": "pnpm exec playwright install --with-deps chromium",
		"prepare": "husky",
		"release": "pnpm build && changeset publish",
		"sb": "pnpm --filter @repobuddy/storybook",
		"test": "turbo test",
		"v": "turbo check build cov",
		"verify": "turbo check build cov",
		"verify:ci": "turbo check build cov --concurrency=1",
		"version": "changeset version && node scripts/update-version-tags.mjs"
	},
	"dependencies": {
		"@biomejs/biome": "2.4.14",
		"@changesets/changelog-github": "^0.7.0",
		"@changesets/cli": "^2.29.7",
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^20.0.0",
		"@repobuddy/biome": "2.3.1",
		"@types/react": "^19.2.5",
		"husky": "^9.1.7",
		"knip": "^6.0.0",
		"playwright": "^1.57.0",
		"rimraf": "^6.1.0",
		"turbo": "^2.9.0",
		"typescript": "^6.0.0"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"npm-run-all2": "^8.0.4"
	},
	"packageManager": "pnpm@10.33.3"
}
